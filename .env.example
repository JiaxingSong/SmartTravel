# Anthropic (required)
ANTHROPIC_API_KEY=

# Amadeus — flights + hotels cash prices
# Sign up: https://developers.amadeus.com/
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_ENVIRONMENT=test

# seats.aero — flight award/points availability
# Sign up: https://seats.aero/
SEATS_AERO_API_KEY=

# Ticketmaster — event/ticket prices
# Sign up: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# Browser sources (requires: pip install smart-travel[browser])
# BROWSER_HEADLESS=true
# BROWSER_TIMEOUT_MS=30000

# Cache settings
# CACHE_BACKEND=memory          # "memory" (default) or "postgres"
# CACHE_TTL_FLIGHTS=600         # 10 min
# CACHE_TTL_HOTELS=1800         # 30 min
# CACHE_TTL_TICKETS=1200        # 20 min
# CACHE_MAX_ENTRIES=500         # in-memory only

# Memory / session persistence
# MEMORY_BACKEND=memory         # "memory" (default) or "postgres"

# PostgreSQL (required for cache/memory postgres backends)
# docker compose up -d to start a local instance
# POSTGRES_DSN=postgresql://smarttravel:smarttravel_dev@localhost:5432/smarttravel
