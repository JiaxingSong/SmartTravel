# Anthropic (required — used automatically by claude-agent-sdk)
ANTHROPIC_API_KEY=

# Browser settings
# BROWSER_HEADLESS=true
# BROWSER_TIMEOUT_MS=30000

# Price monitor check interval in minutes (default: 5)
# MONITOR_CHECK_INTERVAL=5

# Cache settings
# CACHE_TTL=300
# CACHE_MAX_ENTRIES=500

# Award account store
# Path to the JSON file storing loyalty account credentials
# ACCOUNT_STORE_PATH=.smart_travel_accounts.json
# Key for XOR obfuscation of the account file (set to any string; empty = plaintext)
# ACCOUNT_STORE_KEY=
# Directory for persisted Playwright browser sessions (one file per account)
# SESSION_DIR=.smart_travel_sessions
# Hours before a saved browser session is considered stale and re-login is forced
# SESSION_MAX_AGE_HOURS=12

# Account pool auto-registration
# Base email for +tag addressing (e.g. user@gmail.com -> user+united_abc@gmail.com)
# POOL_BASE_EMAIL=
# Minimum accounts to maintain per airline in the pool (default: 2)
# POOL_MIN_ACCOUNTS=2

# CAPTCHA solving (needed for Outlook email registration)
# Get API key from https://anti-captcha.com (~$0.003/solve)
# ANTICAPTCHA_API_KEY=
